#!/usr/bin/env bash
# ============================================================
#  colab_setup.sh — Ollama + bore tunnel setup for Google Colab
#  Usage:
#    curl -fsSL <url>/run | bash
#    curl -fsSL <url>/run | bash -s -- --port 43945
#    curl -fsSL <url>/run | bash -s -- --model llama3.1:8b
# ============================================================

set -e

# ---------- defaults ----------
MODEL="smollm2:1.7b" # leve
BORE_PORT=""          # empty = random
BORE_SECRET=""
OLLAMA_PORT=11434

# ---------- parse args ----------
while [[ $# -gt 0 ]]; do
  case "$1" in
    --port)    BORE_PORT="$2";    shift 2 ;;
    --model)   MODEL="$2";        shift 2 ;;
    --secret)  BORE_SECRET="$2";  shift 2 ;;
    *) echo "Unknown arg: $1"; shift ;;
  esac
done

# ---------- colors ----------
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
RESET='\033[0m'

echo ""
echo -e "${BOLD}╔══════════════════════════════════════════╗${RESET}"
echo -e "${BOLD}║     Colab Ollama + bore setup v1.0       ║${RESET}"
echo -e "${BOLD}╚══════════════════════════════════════════╝${RESET}"
echo ""

# ── 1. zstd ──────────────────────────────────────────────────
echo -e "${CYAN}[1/5] Installing zstd...${RESET}"
apt-get install -y zstd -qq > /dev/null 2>&1

# ── 2. Ollama ─────────────────────────────────────────────────
echo -e "${CYAN}[2/5] Installing Ollama...${RESET}"
if ! command -v ollama &> /dev/null; then
  curl -fsSL https://ollama.com/install.sh | sh > /dev/null 2>&1
fi

# Kill any existing ollama
pkill -f ollama 2>/dev/null || true
sleep 2

# Start ollama bound to all interfaces
echo -e "${CYAN}      Starting Ollama on 0.0.0.0:${OLLAMA_PORT}...${RESET}"
OLLAMA_HOST=0.0.0.0:${OLLAMA_PORT} ollama serve > /tmp/ollama.log 2>&1 &
OLLAMA_PID=$!

# Wait for ollama to be ready
for i in $(seq 1 15); do
  if curl -s http://localhost:${OLLAMA_PORT} > /dev/null 2>&1; then
    break
  fi
  sleep 1
done

echo -e "      Ollama ${GREEN}✓ running${RESET} (pid $OLLAMA_PID)"

# ── 3. Pull model ─────────────────────────────────────────────
echo -e "${CYAN}[3/5] Pulling model: ${MODEL}...${RESET}"
ollama pull "$MODEL"
echo -e "      Model ${GREEN}✓ ready${RESET}"

# ── 4. bore ──────────────────────────────────────────────────
echo -e "${CYAN}[4/5] Installing bore...${RESET}"
if ! command -v bore &> /dev/null; then
  BORE_URL=$(curl -s https://api.github.com/repos/ekzhang/bore/releases/latest \
    | python3 -c "
import sys,json
d=json.load(sys.stdin)
for a in d['assets']:
    if 'x86_64-unknown-linux-musl' in a['name']:
        print(a['browser_download_url'])
        break
")
  curl -fsSL "$BORE_URL" | tar xz -C /usr/local/bin/
fi
echo -e "      bore ${GREEN}✓ installed${RESET}"

# ── 5. Start bore tunnel ──────────────────────────────────────
echo -e "${CYAN}[5/5] Opening bore tunnel...${RESET}"

BORE_CMD="bore local ${OLLAMA_PORT} --to bore.pub"
[[ -n "$BORE_PORT" ]]   && BORE_CMD="$BORE_CMD --port $BORE_PORT"
[[ -n "$BORE_SECRET" ]] && BORE_CMD="$BORE_CMD --secret $BORE_SECRET"

# Start bore and capture the port
bore local ${OLLAMA_PORT} --to bore.pub \
  ${BORE_PORT:+--port $BORE_PORT} \
  ${BORE_SECRET:+--secret $BORE_SECRET} \
  > /tmp/bore.log 2>&1 &

BORE_PID=$!

# Wait and extract port
REMOTE_PORT=""
for i in $(seq 1 15); do
  REMOTE_PORT=$(grep -oP 'bore\.pub:\K[0-9]+' /tmp/bore.log 2>/dev/null | head -1)
  [[ -n "$REMOTE_PORT" ]] && break
  sleep 1
done

if [[ -z "$REMOTE_PORT" ]]; then
  echo -e "${YELLOW}⚠ Could not detect bore port. Check /tmp/bore.log${RESET}"
  cat /tmp/bore.log
  exit 1
fi

BASE_URL="http://bore.pub:${REMOTE_PORT}/v1"

# ── Output ────────────────────────────────────────────────────
echo ""
echo -e "${BOLD}╔══════════════════════════════════════════════════════════╗${RESET}"
echo -e "${BOLD}║                    ✅  READY                             ║${RESET}"
echo -e "${BOLD}╠══════════════════════════════════════════════════════════╣${RESET}"
echo -e "${BOLD}║  Model     :${RESET} ${MODEL}"
echo -e "${BOLD}║  Ollama    :${RESET} http://localhost:${OLLAMA_PORT}"
echo -e "${BOLD}║  Base URL  :${RESET} ${BASE_URL}"
echo -e "${BOLD}║  bore PID  :${RESET} ${BORE_PID}"
echo -e "${BOLD}╚══════════════════════════════════════════════════════════╝${RESET}"
echo ""
echo -e "${YELLOW}  Copy for OpenClaude (run on your machine):${RESET}"
echo ""
echo -e "${GREEN}  export CLAUDE_CODE_USE_OPENAI=1${RESET}"
echo -e "${GREEN}  export OPENAI_BASE_URL=${BASE_URL}${RESET}"
echo -e "${GREEN}  export OPENAI_MODEL=${MODEL}${RESET}"
echo ""
echo -e "${GREEN}  openclaude${RESET}"
echo ""
echo -e "  ${CYAN}Logs: /tmp/ollama.log | /tmp/bore.log${RESET}"
echo ""

# Keep bore alive in foreground so Colab doesn't kill it
wait $BORE_PID
